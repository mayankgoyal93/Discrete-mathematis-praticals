#include <iostream>
#include <vector>
using namespace std;

int main() {
    int V, E;

    cout << "Enter number of vertices: ";
    cin >> V;

    cout << "Enter number of edges: ";
    cin >> E;

    // Adjacency List
    vector<vector<int>> adj(V);

    cout << "Enter edges (u v) for undirected graph:\n";

    for (int i = 0; i < E; i++) {
        int u, v;
        cin >> u >> v;

        // Add edge both ways (undirected)
        adj[u].push_back(v);
        adj[v].push_back(u);
    }

    // Check if every vertex has degree V-1
    bool isComplete = true;

    for (int i = 0; i < V; i++) {
        if (adj[i].size() != V - 1) {
            isComplete = false;
            break;
        }
    }

    // Output result
    if (isComplete)
        cout << "\nThe graph is a COMPLETE graph.\n";
    else
        cout << "\nThe graph is NOT a complete graph.\n";

    return 0;
}
